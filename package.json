{
  "name": "ninogames",
  "version": "1.0.0",
  "description": "NinoGames — Free PC Game Downloader",
  "author": "nino",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.nino.ninogames",
    "productName": "NinoGames",
    "extraResources": [
      { "from": "resources/", "to": ".", "filter": ["**/*"] }
    ],
    "win": {
      "target": "portable",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "icon": "resources/icon.icns"
    },
    "linux": {
      "icon": "resources/icon.png"
    }
  }
}
